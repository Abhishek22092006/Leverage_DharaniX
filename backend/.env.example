# App
PROJECT_NAME="Land Ownership Information System API"
API_V1_PREFIX="/api"

# Security
SECRET_KEY="replace-with-a-strong-random-secret"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_DAYS=7

# Database (Supabase PostgreSQL + SQLAlchemy sync)
# Format: postgresql+psycopg2://postgres:[YOUR_DB_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL="postgresql+psycopg2://postgres:[YOUR_DB_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Frontend CORS (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
